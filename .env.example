# OpenAI API Key (必須)
# https://platform.openai.com/api-keys から取得できます
OPENAI_API_KEY=sk-your-api-key-here

# JWT認証の設定
# AUTH_USERNAMEとAUTH_PASSWORDでログイン認証を行い、JWTトークンを発行します
# 未設定の場合はデフォルト値 (demo / demo123) が使用されます
AUTH_USERNAME=your-username
AUTH_PASSWORD=your-secure-password

# JWT署名用シークレット（未設定の場合はデフォルト値が使用されます）
JWT_SECRET=your-jwt-secret-key

# 許可するオリジン（カンマ区切りで複数指定可能）
# ALLOWED_ORIGINS=https://your-frontend.example.com,https://another-origin.example.com

# サーバーポート (オプション、デフォルト: 3000)
# PORT=3000
